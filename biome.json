{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/src/**/*",
      "**/.vscode/**/*",
      "**/biome.json",
      "**/components.json",
      "**/image.d.ts",
      "**/index.html",
      "**/package.json",
      "**/type.d.ts",
      "**/tsconfig.json",
      "**/tsr.config.json",
      "**/vite.config.ts",
      "**/vitest.config.ts",
      "**/playwright.config.ts",
      "**/tests/**/*",
      "!**/src/routeTree.gen.ts",
      "!**/src/styles.css",
      "!**/.agents/**/*",
      "!**/.claude/**/*",
      "!**/.codex/**/*"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
