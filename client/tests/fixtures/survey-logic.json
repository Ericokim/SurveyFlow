        "order": 6,
        "sectionId": "work",
        "required": false
      },
      {
        "id": "w2",
        "type": "short_text",
        "title": "Years of experience",
        "order": 7,
        "sectionId": "work",
        "required": false
      },
      {
        "id": "w3",
        "type": "short_text",
        "title": "Motivation letter",
        "order": 8,
        "sectionId": "work",
        "required": false
      }
    ],
    "visibilityRules": [],
    "navigationRules": [
      {
        "id": "nav-q3-kenyan-w2",
        "fromSectionId": "bio",
        "priority": 100,
        "when": { "questionId": "q3", "operator": "equals", "value": "Kenyan" },
        "action": { "type": "jump_to_question", "targetQuestionId": "w2" }
      },
      {
        "id": "nav-q3-other-q5",
        "fromSectionId": "bio",
        "priority": 90,
        "when": { "questionId": "q3", "operator": "equals", "value": "Other" },
        "action": { "type": "jump_to_question", "targetQuestionId": "q5" }
      },
      {
        "id": "nav-q3-african-q4",
        "fromSectionId": "bio",
        "priority": 80,
        "when": { "questionId": "q3", "operator": "equals", "value": "African" },
        "action": { "type": "jump_to_question", "targetQuestionId": "q4" }
      },
      {
        "id": "nav-q3-top-work",
        "fromSectionId": "bio",
        "priority": 70,
        "when": { "questionId": "q3", "operator": "equals", "value": "TopWork" },
        "action": { "type": "jump", "targetSectionId": "work" }
      },
      {
        "id": "nav-q3-exit",
        "fromSectionId": "bio",
        "priority": 60,
        "when": { "questionId": "q3", "operator": "equals", "value": "Exit" },
        "action": { "type": "terminate" }
      }
    ]
  },
  "scenarios": [
    {
