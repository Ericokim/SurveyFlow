        "sectionId": "bio",
        "required": true
      },
      {
        "id": "q3",
        "type": "single_choice",
        "title": "Nationality?",
        "options": ["Kenyan", "Other", "African", "TopWork", "Exit", "Continue"],
        "order": 3,
        "sectionId": "bio",
        "required": true
      },
      {
        "id": "q4",
        "type": "short_text",
        "title": "Select your African country of origin",
