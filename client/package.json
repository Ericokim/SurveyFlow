{
	"name": "surveyflow-client",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsr generate && vite build",
		"lint": "eslint .",
		"test": "npm run test:unit",
		"test:unit": "node --test tests/unit/*.test.mjs",
		"clean:test-artifacts": "rm -rf tests/allure-results tests/allure-report tests/test-results allure-results allure-report test-results playwright-report",
		"prepare:allure": "node tests/e2e/helpers/prepare-allure.mjs",
		"test:e2e": "npm run clean:test-artifacts && npm run prepare:allure && playwright test --config playwright.config.ts",
		"test:e2e:headed": "npm run clean:test-artifacts && npm run prepare:allure && playwright test --config playwright.config.ts --headed",
		"allure:generate": "rm -rf tests/allure-report && ./node_modules/.bin/allure generate ./tests/allure-results --output tests/allure-report",
		"allure:open": "./node_modules/.bin/allure open tests/allure-report",
		"preview": "vite preview",
		"route:generate": "tsr generate",
		"route:watch": "tsr watch"
	},
	"dependencies": {
