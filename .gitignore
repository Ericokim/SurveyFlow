# SurveyFlow - Git Ignore Rules

# =====================================
# Dependencies & Package Managers
# =====================================
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# =====================================
# Environment Variables & Secrets
# =====================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# =====================================
# Build Outputs & Distribution
# =====================================
dist/
dist-ssr/
build/
.vite/
.parcel-cache/

# =====================================
# Development & Cache Files
# =====================================
.cache/
.eslintcache
.stylelintcache
.nitro/
.tanstack/

# =====================================
# Logs & Debug Files
# =====================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =====================================
# Testing & Coverage
# =====================================
coverage/
.coverage/
.nyc_output/
test-results/
playwright-report/
blob-report/
playwright/.cache/
allure-results/
allure-report/
client/tests/allure-results/
client/tests/allure-report/
client/tests/test-results/
client/tests/blob-report/
client/tests/e2e/test-results/
client/tests/e2e/playwright-report/
client/tests/screenshots/*.png
!client/tests/screenshots/.gitkeep

# =====================================
# Runtime & Process Files
# =====================================
pids/
*.pid
*.seed
*.pid.lock

# =====================================
# Temporary Files
# =====================================
tmp/
temp/
.tmp/

# =====================================
# Editor & IDE Files
# =====================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# =====================================
# OS Generated Files
# =====================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =====================================
# Application Specific
# =====================================
# Multer scratch space for logo uploads before they are pushed to S3
uploads/
!uploads/.gitkeep

# NOTE: client/src/routeTree.gen.js is generated by `tsr generate`, but it is
# deliberately committed so the repo builds without a pre-build step. Do not add
# it here. (The old rule named routeTree.gen.ts, which this project never had.)

# =====================================
# Claude Code & AI Tools
# =====================================
# The whole directory is local tooling state — sessions, cache, installed skills.
# (The previous comment claimed agent config was kept, but the bare `.claude`
# rule below it already ignored everything, so the two contradicted each other.)
.claude/

# Scratch notes written by AI tooling. Anchored to the repo root: the old bare
# `docs` rule matched any directory named docs at any depth, which silently
# excluded server/docs — the OpenAPI document the API imports at boot — and would
# have made production fail to start with an unresolvable module.
/docs/

.mcp/
.mcp.json

# =====================================
# Development Tools
# =====================================
.prettierignore

# =====================================
# SurveyFlow Specific
# =====================================
# API testing files
http/
*.http
*.rest

# Documentation artifacts
AGENTS.md
CLAUDE.md
projectplan.md

# Database dumps
*.dump
*.sql

# Backup files
*.backup
*.bak

# Netlify
.netlify/
