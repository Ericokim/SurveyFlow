# Server
PORT=5001
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/surveyflow

# JWT
JWT_SECRET=your-super-secret-key-min-256-bits
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Frontend
FRONTEND_URL=http://localhost:5173

# SMS Gateway (Optional - for survey invitations via SMS)
# Leave these empty to disable SMS functionality
SMS_API_KEY=
SMS_USERNAME=
SMS_SENDER_ID=SurveyFlow
SMS_GATEWAY_URL=https://api.africastalking.com/version1/messaging

# Email (Password Reset & Notifications)
# Sent via external Comms API (HTTP POST). Leave empty to log emails to console (development mode).
COMMS_API_URL=https://comms.example.com
COMMS_APP_ID=your-comms-app-id
EMAIL_FROM=no-reply@example.com


# AWS S3 (Image Uploads) - Optional
# Replace with your actual AWS credentials from IAM console
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET_NAME=survey-app-prod-uploads
